# ============================================
# CreatorFirst Server - Environment Variables
# ============================================

# --- Supabase (Required) ---
# Get the Service Role key (not anon key!) from your Supabase dashboard
# Project Settings > API > service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- YouTube Data API (Required for duration + channel avatar) ---
# Get from https://console.cloud.google.com/apis/credentials
# Enable the "YouTube Data API v3" for your project first
YOUTUBE_API_KEY=your-youtube-api-key

# --- CORS (Optional, defaults to creatorfirst.vercel.app) ---
CORS_ORIGIN=https://creatorfirst.vercel.app

# --- Port (Optional, defaults to 3001) ---
PORT=3001
